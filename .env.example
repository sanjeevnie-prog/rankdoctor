# Convex — where waitlist emails are stored
# Run `npx convex dev` once; it fills this in automatically in .env.local
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOYMENT=

# Resend — for sending the welcome email
# https://resend.com/api-keys
RESEND_API_KEY=

# Sender address.
# Local: keep default. Production: verify a domain in Resend and change.
# https://resend.com/docs/dashboard/domains/introduction
RESEND_FROM="Ninety <onboarding@resend.dev>"

# Where replies go (your inbox)
NOTIFICATION_EMAIL=hello@growthx.club
