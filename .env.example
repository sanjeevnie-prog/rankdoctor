# Convex deployment URL (e.g. https://your-deployment.convex.cloud)
NEXT_PUBLIC_CONVEX_URL=

# Resend API key for the existing ninety waitlist emails
RESEND_API_KEY=

# Resend "from" address (e.g. "Ninety <onboarding@resend.dev>")
RESEND_FROM=

# Where Resend reply-to lands (your inbox)
NOTIFICATION_EMAIL=

# Anthropic API key — used by lib/diagnose.ts to synthesize the diagnosis
ANTHROPIC_API_KEY=

# Google PageSpeed Insights API key — used by lib/fetchers/pagespeed
PAGESPEED_API_KEY=

# Long random string. Required to view /admin/queue and approve diagnoses.
ADMIN_KEY=
